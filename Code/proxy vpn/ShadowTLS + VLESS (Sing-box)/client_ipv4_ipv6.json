		"rules": [
			{
				"action": "sniff"
			},
			{
				"ip_cidr": ["77.88.8.8/32"],
				"outbound": "direct"
			},
			{
				"action": "hijack-dns",
				"type": "logical",
				"mode": "or",
				"rules": [
					{
						"port": 853
					},
					{
						"protocol": "dns"
					},
					{
						"port": 53
					}
				]
			},
			{
				"action": "reject",
				"type": "logical",
				"mode": "or",
				"rules": [
					{
						"port": 853
					},
					{
						"network": "udp",
						"port": 443
					},
					{
						"protocol": "stun"
					}
				]
			},
			{
				"action": "route",
				"ip_is_private": true,
				"outbound": "direct"
			},
			{
				"action": "route",
				"rule_set": [
                    "geosite-youtube",
                    "geosite-telegram",
                    "geosite-tiktok",
                    "geosite-gemini",
                    "geosite-discord"
				],
				"outbound": "server1"
			},
			{
				"action": "route",
				"rule_set": [
					"geosite-category-ru",
					"geosite-category-gov-ru",
					"geosite-category-bank-ru",
					"geosite-category-media-ru",
					"geosite-category-travel-ru",
					"geosite-category-medicine-ru",
					"geosite-category-ecommerce-ru",
					"geosite-category-entertainment-ru",
					"geosite-yandex"
				],
				"outbound": "direct"
			},
			{
				"action": "resolve",
				"strategy": "prefer_ipv4",
				"disable_cache": false,
				"client_subnet": "5.255.255.0/24"
			},
			{
				"action": "route",
				"rule_set": "geoip-ru",
				"outbound": "direct"
			}
		],
		"final": "auto",
		"default_domain_resolver": "dns_resolver",
		"auto_detect_interface": true
	},
	"inbounds": [
		{
			"type": "tun",
			"tag": "tun-in",
			"address": ["172.16.0.1/30", "fdfe:dcba:9876::1/126"],
			"auto_route": true,
			"strict_route": true,
			"stack": "system",
			"udp_timeout": "3m",
			"mtu": 1280
		}
	],
	"outbounds": [
		{
			"tag": "auto",
			"type": "urltest",
			"url": "http://www.gstatic.com/generate_204",
			"interval": "1m",
			"tolerance": 200,
			"interrupt_exist_connections": false,
			"outbounds": ["server1", "server2"]
		},
		{
			"tag": "server1",
			"type": "shadowsocks",
			"method": "2022-blake3-aes-128-gcm",
			"password": "shadowsocks password same as on server1",
			"detour": "shadowtls-server1",
			"tcp_fast_open": true,
			"udp_over_tcp": true,
			"multiplex": {
				"enabled": true,
				"protocol": "smux",
				"max_streams": 8,
				"min_streams": 1,
				"padding": true
			}
		},
		{
			"type": "shadowtls",
			"tag": "shadowtls-server1",
			"server": "server1_ip_address",
			"server_port": 443,
			"version": 3,
			"password": "shadowtls user password same as on server1",
			"tcp_fast_open": true,
			"tls": {
				"enabled": true,
				"server_name": "SNI (address which you're going to use for security)",
				"utls": {
					"enabled": true,
					"fingerprint": "chrome"
				}
			}
		},
		{
			"tag": "server2",
			"type": "shadowsocks",
			"method": "2022-blake3-aes-128-gcm",
			"password": "shadowsocks password same as on server",
			"detour": "shadowtls-server2",
			"tcp_fast_open": true,
			"udp_over_tcp": true,
			"multiplex": {
				"enabled": true,
				"protocol": "smux",
				"max_streams": 8,
				"min_streams": 1,
				"padding": true
			}
		},
		{
			"type": "shadowtls",
			"tag": "shadowtls-server2",
			"server": "server2_ip_address",
			"server_port": 443,
			"version": 3,
			"password": "shadowtls user password same as on server2",
			"tcp_fast_open": true,
			"tls": {
				"enabled": true,
				"server_name": "SNI (address which you're going to use for security)",
				"utls": {
					"enabled": true,
					"fingerprint": "chrome"
				}
			}
		},
		{
			"type": "direct",
			"tag": "direct"
		},
		{
			"type": "block",
			"tag": "block"
		}
	]
