{
	"log": {
		"level": "debug",
		"timestamp": true
	},
	"dns": {
		"servers": [
			{
				"tag": "dns_fakeip",
				"type": "fakeip",
				"inet4_range": "198.18.0.0/15",
				"inet6_range": "fc00::/18"
			},
			{
				"tag": "dns_hosts",
				"type": "hosts",
				"predefined": {
					"one.one.one.one": [ 
						"1.1.1.1",
						"1.0.0.1",
						"2606:4700:4700::1111",
						"2606:4700:4700::1001"
					]	
				}
			},
			{
				"tag": "dns_proxy",
				"type": "https",
				"detour": "auto",
				"server": "one.one.one.one",
				"domain_resolver": "dns_hosts",
				"server_port": 443
			},

			{
				"tag": "dns_direct",
				"type": "https",
				"server": "common.dot.dns.yandex.net",
				"domain_resolver": "dns_resolver",
				"server_port": 443
			},
			{
				"tag": "dns_resolver",
				"type": "udp",
				"server": "77.88.8.8"
			}

		],
		"rules": [
			{
				"query_type": [
					"PTR"
				],
				"server": "dns_direct"
			},
			{
				"rule_set": [
					"geosite-telegram",
					"geosite-tiktok",
					"geosite-gemini",
					"geosite-youtube",
					"geosite-discord"
				],
				"server": "dns_fakeip"
			},
			{
				"rule_set": [
                    "geosite-category-ru",
                    "geosite-category-gov-ru",
                    "geosite-category-bank-ru",
                    "geosite-category-media-ru",
                    "geosite-category-travel-ru",
                    "geosite-category-medicine-ru",
                    "geosite-category-ecommerce-ru",
                    "geosite-category-entertainment-ru",
                    "geosite-yandex"
				],
				"server": "dns_direct"
			},
			{
				"action": "route",
				"type": "logical",
				"mode": "and", 
				"rules": [
					{
						"domain_suffix": [
							".lan",
							".localdomain",
							".example",
							".invalid",
							".localhost",
							".test",
							".local",
							".home.arpa",
							".msftconnecttest.com",
							".msftncsi.com"
						],
						"invert": true
					},
					{
						"query_type": ["A", "AAAA"]
					}
				],
				"server": "dns_fakeip"
			}
		],
		"disable_cache": false,
		"disable_expire": false,
		"independent_cache": true,
		"cache_capacity": 2048,
		"reverse_mapping": true,
		"client_subnet": "5.255.255.0/24",
		"final": "dns_proxy",
		"strategy": "prefer_ipv4"
	},
	"route": {
		"rule_set": [
			{
				"tag": "geosite-category-ru",
