{
	"route": {
		"rule_set": [
            {
                "tag": "geosite-tiktok",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-tiktok.srs",
                "download_detour": "direct"
            },
            {
                "tag": "geosite-gemini",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-google-gemini.srs",
                "download_detour": "direct"
            }
		],
		"rules": [
			{
				"rule_set": [
                    "geosite-tiktok",
				    "geosite-gemini"
                ],
				"outbound": "warp-out"
			}
		],
		"final": "direct"
	},
	"endpoints": [
		{
			"type": "wireguard",
			"tag": "warp-out",
			"address": ["172.16.0.2/32", "cloudflare wireguard.conf ipv6 address"],
			"private_key": "cloudflare wirguard.conf private key",
			"peers": [
				{
					"address": "engage.cloudflareclient.com",
					"port": 2408,
					"public_key": "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=",
					"allowed_ips": ["0.0.0.0/0", "::/0"],
					"reserved": [0, 0, 0]
				}
			]
		}
	],
	"inbounds": [
		{
			"type": "vless",
			"listen": "::",
			"listen_port": 443,
			"users": [
				{
					"uuid": "user1 uuid (`sing-box generate uuid`)"
				},
				{
					"uuid": "user2 uuid (`sing-box generate uuid`)"
				}
			],
			"tls": {
				"enabled": true,
				"server_name": "SNI (address which you're going to use for security)",
				"reality": {
					"enabled": true,
					"handshake": {
						"server": "SNI (address which you're going to use for security)",
						"server_port": 443
					},
					"private_key": "public key (one of the keys from `sing-box generate reality-keypair`)",
					"short_id": [
						"short id (`openssl rand -hex 8`)"
					]
				}
			},
			"transport": {
				"type": "http",
				"host": ["same as server_name"]
			}
		}
	],
	"outbounds": [
		{
			"type": "direct",
			"tag": "direct"
		}
	]
}
